        <div class="recommend_container">
          <div class="item" v-for="hot in hotList" :key="hot.id" @click="() => {
            emit('isShowSearch')
            $router.push('/article/' + hot.id)
          }">
            {{ hot.articleTitle }}
            <div>
              <SvgIcon name="heat"/>
              <span>{{ hot.visitCount }}</span></div>
          </div>
        </div>